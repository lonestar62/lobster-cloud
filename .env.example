PORT=4000
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://postgres:password@localhost:5432/lobster_cloud

# Redis (optional — falls back to in-memory Map if not set)
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-in-production-use-long-random-string

# Admin credentials
ADMIN_EMAIL=admin@lobster.cloud
ADMIN_PASSWORD=change-me-in-production
ADMIN_TOKEN=change-me-admin-token
